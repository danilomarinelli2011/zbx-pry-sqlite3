# Identidade do proxy (nome deve ser idêntico ao cadastrado no Zabbix Server)
ZBX_PROXY_HOSTNAME=

# Endereço do Zabbix Server (pode ser IP ou FQDN)
ZBX_SERVER_HOST=
ZBX_SERVER_PORT=10051

# 0 = active (proxy inicia a conexão)  |  1 = passive
ZBX_PROXY_MODE=0

# Descomente se usar criptografia PSK
# ZBX_TLS_PSK_IDENTITY=ProxyPSK
